{
  "expo": {
    "name": "FXトレード日記",
    "slug": "fx-trade-journal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fxtradejournal.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.fxtradejournal.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.READ_MEDIA_IMAGES",
        "com.android.vending.BILLING",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "fx-trade-journal",
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "トレードのチャート画像を添付するために写真へのアクセスを使用します。"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/splash-icon.png",
          "color": "#4F7EF7",
          "sounds": []
        }
      ],
      "expo-sqlite",
      "expo-document-picker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8a7d7dbf-6b86-4ed9-bf69-54d253c4251d"
      }
    }
  }
}
