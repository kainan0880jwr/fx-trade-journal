{
  "expo": {
    "name": "FXトレードログ",
    "slug": "fx-trade-journal",
    "version": "1.2.2",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fxtradejournal.ios",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleLocalizations": [
          "ja",
          "en",
          "de",
          "fr",
          "es",
          "it"
        ],
        "CFBundleDevelopmentRegion": "ja"
      }
    },
    "android": {
      "package": "com.fxtradejournal.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.READ_MEDIA_IMAGES",
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "fx-trade-journal",
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "トレードのチャート画像を添付するために写真へのアクセスを使用します。",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/splash-icon.png",
          "color": "#4F7EF7",
          "sounds": []
        }
      ],
      [
        "expo-sqlite",
        {
          "useSQLCipher": true
        }
      ],
      "expo-document-picker",
      "expo-font",
      "expo-updates",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "生体認証でアプリをロックし、トレード記録を保護します。"
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8a7d7dbf-6b86-4ed9-bf69-54d253c4251d",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 3000,
      "codeSigningCertificate": "./certs/certificate.pem",
      "codeSigningMetadata": {
        "keyid": "main",
        "alg": "rsa-v1_5-sha256"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8a7d7dbf-6b86-4ed9-bf69-54d253c4251d"
      }
    }
  }
}
